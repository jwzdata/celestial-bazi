# Turso Database Configuration (fill in Vercel project settings > Environment Variables)
# 1. Register Turso: https://turso.tech
# 2. Create database: turso db create bazi
# 3. Get URL: turso db show bazi --url
# 4. Get Token: turso db tokens create bazi
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-token-here

# JWT Secret (use a random hex string in production)
JWT_SECRET=your-random-hex-string-here
