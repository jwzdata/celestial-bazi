# Turso 数据库配置（在 Vercel 项目设置 > Environment Variables 中填入）
# 1. 注册 Turso: https://turso.tech
# 2. 创建数据库: turso db create bazi
# 3. 获取 URL: turso db show bazi --url
# 4. 获取 Token: turso db tokens create bazi
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-token-here

# JWT 密钥（生产环境请换成随机字符串）
JWT_SECRET=your-random-hex-string-here
